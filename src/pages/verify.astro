---
import "../styles/article.css";
import Card from "../components/Card.astro";
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";

import pgp from "../config/pgp.json";
const fingerprint = pgp.fingerprintFormatted;
const keyoxideUrl = `https://keyoxide.org/hkp/${pgp.fingerprint}`;
---

<Layout title="Verify — shaun." description="Verify my identity via PGP, Keyoxide, and DID." pagefindIgnore>
  <div slot="left">
    <Card>
      <h2 class="no-mt">Quick links</h2>
      <ul class="link-list">
        <li><a href={keyoxideUrl} target="_blank" rel="noopener">Keyoxide profile</a></li>
        <li><a href="/pgp-key.asc">Download public key</a></li>
        <li><a href="#blog-posts">Verifying blog posts</a></li>
        <li><a href="/.well-known/did.json">DID document</a></li>
      </ul>
    </Card>
  </div>

  <div slot="right">
    <Card>
      <article>
        <h1 class="no-mt">Verify My Identity</h1>
        <p>This page lets you confirm that this site and its accounts are controlled by me.</p>

        <hr />

        <h2>
          <Icon type="lucide" name="key-round" width={20} height={20} class="glow-icon inline-icon" />
          Keyoxide
        </h2>
        <p>
          <a href={keyoxideUrl} target="_blank" rel="noopener">{keyoxideUrl}</a>
        </p>
        <p>Keyoxide is an open-source identity verification tool that links my PGP key to the accounts I control.</p>

        <hr />

        <h2>
          <Icon type="lucide" name="fingerprint" width={20} height={20} class="glow-icon inline-icon" />
          PGP Public Key
        </h2>
        <p><strong>Fingerprint:</strong></p>
        <pre class="fingerprint">{fingerprint}</pre>
        <p><a href="/pgp-key.asc">Download public key (.asc)</a></p>
        <details>
          <summary>View raw key</summary>
          <pre class="pgp-key">-----BEGIN PGP PUBLIC KEY BLOCK-----

